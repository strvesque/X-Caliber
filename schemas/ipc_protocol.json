{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "title": "subdomain",
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "subdomains", "count", "timestamp"],
      "properties": {
        "target": {"type": "string"},
        "subdomains": {"type": "array", "items": {"type": "string"}},
        "count": {"type": "integer", "minimum": 0},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    {
      "title": "port_scan",
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "open_ports", "scan_time", "timestamp"],
      "properties": {
        "target": {"type": "string"},
        "open_ports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["port", "protocol", "state"],
            "properties": {
              "port": {"type": "integer"},
              "protocol": {"type": "string"},
              "state": {"type": "string"},
              "service": {"type": "string"}
            }
          }
        },
        "scan_time": {"type": "number"},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    {
      "title": "http_probe",
      "type": "object",
      "additionalProperties": false,
      "required": ["urls", "results", "timestamp"],
      "properties": {
        "urls": {"type": "array", "items": {"type": "string"}},
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "status_code", "response_time"],
            "properties": {
              "url": {"type": "string"},
              "status_code": {"type": "integer"},
              "response_time": {"type": "number"},
              "title": {"type": "string"},
              "content_length": {"type": "integer"}
            }
          }
        },
        "timestamp": {"type": "string", "format": "date-time"}
      }
    }
  ]
}
